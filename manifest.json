{
  "manifest_version": 3,
  "name": "HXLoLi-NaGaMe",
  "version": "3.4.6",
  "description": "HXLoLi 博客受保护页面自动解锁 🔓 (NaGaMe = 眺め = 凝望)",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://hengxin666.github.io/*",
    "https://hxloli.pages.dev/*",
    "*://localhost/*",
    "https://github.com/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://km.woa.qzz.io/*",
    "https://ppt.woa.qzz.io/*",
    "*://*.woa.qzz.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://hengxin666.github.io/HXLoLi/*",
        "https://hxloli.pages.dev/*",
        "*://localhost/*"
      ],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nagame@hxloli.pages.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
